# TGB Enterprise – Environment Configuration
# Copy this file to .env.local for local development.
# Never commit .env.local to version control.

# ── Business Contact Information ────────────────────────────
# WhatsApp business number (E.164 format, no spaces or dashes)
VITE_WHATSAPP_NUMBER=919824817381

# Primary inquiry email address (displayed on site)
VITE_CONTACT_EMAIL=tgbsign@proton.me

# Primary phone number (international format)
VITE_CONTACT_PHONE=+919824817381

# ── Studio Location ─────────────────────────────────────────
VITE_STUDIO_LATITUDE=23.0512243
VITE_STUDIO_LONGITUDE=72.6624139
VITE_MAPS_EMBED_URL=https://maps.google.com/maps?q=23.0512243,72.6624139&z=16&output=embed
VITE_MAPS_LINK=https://maps.app.goo.gl/Uo3hdVGb74ZTquZ69

# ── SEO & Metadata ──────────────────────────────────────────
VITE_SITE_URL=https://www.tgbsign.com
VITE_SITE_NAME=TGB Enterprise

# ── Google Analytics 4 ──────────────────────────────────────
# Get ID from: https://analytics.google.com → Admin → Data Streams
VITE_GA4_MEASUREMENT_ID=G-XXXXXXXXXX

# ── Sentry Error Tracking ───────────────────────────────────
# Get DSN from: https://sentry.io → Settings → Client Keys (DSN)
VITE_SENTRY_DSN=https://examplePublicKey@o123456.ingest.sentry.io/1234567

# ── Email (Resend) ──────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Sender identity shown in the From field
RESEND_FROM_NAME=TGB Sign
RESEND_FROM_EMAIL=info@tgbsign.com

# Where business notifications are delivered
RESEND_TO_EMAIL=tgbsign@proton.me
