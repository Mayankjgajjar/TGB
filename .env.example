# TGB Enterprise – Environment Configuration
# Copy this file to .env.local for local development.
# Never commit .env.local to version control.

# ── Business Contact Information ────────────────────────────
# WhatsApp business number (E.164 format, no spaces or dashes)
VITE_WHATSAPP_NUMBER=919824817381

# Primary inquiry email address
VITE_CONTACT_EMAIL=info@tgbenterprise.com

# Primary phone number (international format)
VITE_CONTACT_PHONE=+919824817381

# ── Studio Location ─────────────────────────────────────────
VITE_STUDIO_LATITUDE=23.0512243
VITE_STUDIO_LONGITUDE=72.6624139
VITE_MAPS_EMBED_URL=https://maps.google.com/maps?q=23.0512243,72.6624139&z=16&output=embed
VITE_MAPS_LINK=https://maps.app.goo.gl/Uo3hdVGb74ZTquZ69

# ── SEO & Metadata ──────────────────────────────────────────
VITE_SITE_URL=https://www.tgbsign.com
VITE_SITE_NAME=TGB Enterprise

# ── Email (Resend) ──────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Cloudflare Turnstile (CAPTCHA) ──────────────────────────
# Get keys at: https://dash.cloudflare.com → Turnstile
VITE_TURNSTILE_SITE_KEY=0x4AAAAAAA_xxxxxxxxxxxxxxxxxxxxxxxx
TURNSTILE_SECRET_KEY=0x4AAAAAAA_xxxxxxxxxxxxxxxxxxxxxxxx

